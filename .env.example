# Copy this file to .env and fill in real values. Never commit .env.
PORT=3000

# The Google Sheet's ID — the long string in the sheet URL between /d/ and /edit
SHEET_ID=1dwQp7pfHPvYZBQE1O8gGYm4J4RpQCtXqlKFoc8vyn6k

# Tab name + columns. A=Timestamp, B=Name, C=Email, D=Message.
SHEET_RANGE=Sheet1!A:D

# Path (relative to project root) to the service-account JSON key file
GOOGLE_KEY_FILE=service-account.json

# === Morning briefing (morning-briefing.mjs) ===
# AI provider — claude (default) or groq
BRIEFING_AI=claude

# Anthropic Claude (https://console.anthropic.com → API keys)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Groq fallback (https://console.groq.com → API keys)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Supabase (anon/publishable key — only used to read form_submissions)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_TABLE=form_submissions

# Resend (default sender)
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev

# Gmail / NodeMailer (alternate sender — node morning-briefing.mjs run --gmail)
# Requires 2-step verification + an app password from https://myaccount.google.com/apppasswords
GMAIL_USER=
GMAIL_PASS_ARCA=

# Briefing recipient + schedule
BRIEFING_TO=
BRIEFING_TZ=Asia/Manila
BRIEFING_CRON=0 7 * * *
BRIEFING_PORT=3100

# Vercel deploy (only needed once you deploy /api/briefing)
BRIEFING_SECRET=
BRIEFING_DEPLOY_URL=
